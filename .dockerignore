# Ignore node_modules. We install them in the container.
node_modules

# Ignore build output. This is generated in the container.
dist

# Ignore local environment files.
.env
.env.*
!.env.example

# Ignore logs and temporary files.
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore Git directory and other version control files.
.git
.gitignore

# Ignore IDE and editor folders
.idea/
.vscode/

# Ignore Docker specific files from the context
Dockerfile
.dockerignore
